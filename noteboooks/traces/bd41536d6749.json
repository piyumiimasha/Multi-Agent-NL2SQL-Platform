        "sql": "SELECT \n    d.doctor_id,\n    d.first_name,\n    d.last_name,\n    COUNT(CASE WHEN a.status = 'No-Show' THEN 1 END) AS no_show_count,\n    COUNT(a.appointment_id) AS total_appointments,\n    ROUND(COUNT(CASE WHEN a.status = 'No-Show' THEN 1 END) * 100.0 / COUNT(a.appointment_id), 2) AS no_show_rate\nFROM \n    doctors d\nJOIN \n    appointments a ON d.doctor_id = a.doctor_id\nGROUP BY \n    d.doctor_id, d.first_name, d.last_name\nORDER BY \n    no_show_rate DESC\nLIMIT 10;",
